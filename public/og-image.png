<!-- Placeholder: This would be a 1200x630 PNG generated -->
<!-- For now, creating an SVG template that can be converted to PNG -->
<svg width="1200" height="630" viewBox="0 0 1200 630" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background gradient -->
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0F172A;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#581c87;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0F172A;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <rect width="1200" height="630" fill="url(#bgGrad)"/>
  
  <!-- Logo -->
  <text x="600" y="200" font-family="serif" font-size="72" font-weight="300" letter-spacing="16" text-anchor="middle" fill="white">
    FORTUNA
  </text>
  
  <line x1="300" y1="230" x2="900" y2="230" stroke="white" stroke-width="1"/>
  
  <text x="600" y="260" font-family="sans-serif" font-size="20" font-weight="300" letter-spacing="12" text-anchor="middle" fill="white">
    GIVEFORTUNA.IO
  </text>
  
  <!-- Tagline -->
  <text x="600" y="350" font-family="sans-serif" font-size="48" font-weight="600" text-anchor="middle" fill="white">
    Play for Purpose
  </text>
  
  <text x="600" y="420" font-family="sans-serif" font-size="28" font-weight="300" text-anchor="middle" fill="#D1D5DB">
    The world's first on-chain charitable giving platform
  </text>
  
  <!-- Stats -->
  <g transform="translate(200, 480)">
    <text x="0" y="0" font-family="sans-serif" font-size="16" font-weight="500" fill="#A78BFA">100% TRANSPARENT</text>
  </g>
  
  <g transform="translate(480, 480)">
    <text x="0" y="0" font-family="sans-serif" font-size="16" font-weight="500" fill="#A78BFA">PROVABLY FAIR</text>
  </g>
  
  <g transform="translate(750, 480)">
    <text x="0" y="0" font-family="sans-serif" font-size="16" font-weight="500" fill="#A78BFA">ZERO TRUST</text>
  </g>
</svg>
